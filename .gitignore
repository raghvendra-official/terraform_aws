# Terraform local directories
**/.terraform/*
**/.terraform/**
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
!*.tfvars.example
!*.tfvars.json.example

# Terraform plans
*.tfplan
*.plan
plan.out

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# Environment and secret files
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Local editor and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
